      },
      "groupId": "fc_group_1765057689919_0",
      "customScriptOutputType": "vector",
      "customScriptCode": "const getClawRoboticArmCenter = (\n    size, \n    angle, \n    armState\n) => {\n    // 1. Arm Base Offset\n    // In drawRoboticArm: ctx.translate(0, size * 0.25);\n    // This is a displacement of (0, 0.25 * size) in the ship's local frame.\n    // We rotate this offset by the ship's angle to get it in world space.\n    const baseDist = size * 0.25;\n    const baseX = -baseDist * Math.sin(angle);\n    const baseY = baseDist * Math.cos(angle);\n    // 2. Shoulder Segment\n    // Length: size * 0.4\n    // Rotation: Adds armState.shoulder to the current rotation (ship definition)\n    const shoulderLen = size * 0.4;\n    const shoulderAngle = angle + armState.shoulder;\n    const shoulderX = shoulderLen * Math.cos(shoulderAngle);\n    const shoulderY = shoulderLen * Math.sin(shoulderAngle);\n    // 3. Elbow Segment\n    // Length: size * 0.35\n    // Rotation: Adds armState.elbow to the previous rotation\n    const elbowLen = size * 0.35;\n    const elbowAngle = shoulderAngle + armState.elbow;\n    const elbowX = elbowLen * Math.cos(elbowAngle);\n    const elbowY = elbowLen * Math.sin(elbowAngle);\n    // 4. Wrist/Claw Segment\n    // Length: size * 0.2 (Distance to the center point between the claw tips)\n    // Rotation: Adds armState.wrist to the previous rotation\n    const clawLen = size * 0.2;\n    const clawAngle = elbowAngle + armState.wrist;\n    const clawX = clawLen * Math.cos(clawAngle);\n    const clawY = clawLen * Math.sin(clawAngle);\n    // Sum all vectors to get the final relative position\n    return {\n        x: baseX + shoulderX + elbowX + clawX,\n        y: baseY + shoulderY + elbowY + clawY\n    };\n};\n\n// ✅ Launch it with the same values you pass to drawRoboticArm:\n\nconst armState={\"shoulder\":input[1],\"elbow\":input[2],\"wrist\":input[3]}\nconst size=2.5;\nconst angle=input[0].angle;\nconsole.log(JSON.stringify(armState));\nconst zero={\"x\":0,\"y\":0};\nconst center = getClawRoboticArmCenter(size,angle, armState);\nconst real={\"x\":input[0].position.x+center.x,\"y\":input[0].position.y+center.y};\nconsole.log(JSON.stringify(center))\n//return center.x.toFixed(1)+':'+center.y.toFixed(1);\nconsole.log(input[0].angle);\nreturn real;",
      "customScriptManualTrigger": 1765037084151,
      "customScriptLastResult": null,
